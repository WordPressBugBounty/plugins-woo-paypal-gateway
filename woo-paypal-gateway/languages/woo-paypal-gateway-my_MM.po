#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1314
msgid "Invalid payment method. Please try another payment method."
msgstr "ငွေပေးချေမှုနည်းလမ်းမမှန်ပါ။ အခြားငွေပေးချေမှုနည်းလမ်းကိုကြိုးစားပါ။."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1315
msgid "Quasi-cash not supported. Please use another payment method."
msgstr ""
"Quasi-cash ကိုထောက်ပံ့မထားပါ။ ကျေးဇူးပြု၍ အခြားငွေပေးချေမှုနည်းလမ်းတစ်ခုကို "
"အသုံးပြုပါ။."


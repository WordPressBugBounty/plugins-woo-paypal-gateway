#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:453
msgid ""
"Choose where the PayPal buttons should appear on the cart page, either above"
" or below the \"Proceed to Checkout\" button. This applies only to classic "
"cart templates, not the new Cart Blocks layout."
msgstr ""
"Válaszd ki, hogy a PayPal gombok hol jelenjenek meg a kosár oldalon, a "
"\"Tovább a pénztárhoz\" gomb felett vagy alatt. Ez csak a klasszikus kosár "
"sablonokra vonatkozik, nem az új Cart Blocks elrendezésre."

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:457
msgid "Below Proceed to Checkout button"
msgstr "A Tovább a pénztárhoz gomb alatt"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:458
msgid "Above Proceed to Checkout button"
msgstr "A Tovább a pénztárhoz gomb felett"


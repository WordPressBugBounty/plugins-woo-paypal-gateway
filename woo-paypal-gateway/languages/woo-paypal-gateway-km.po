msgid "Security code (CVV) didn’t match."
msgstr "សូម្បីតែលេខកូដសុវត្ថិភាព (CVV) មិនត្រូវគ្នាទេ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:345
msgid "The payer opened a dispute with PayPal."
msgstr "អ្នកបង់ប្រាក់បានបើកការប្រកាន់ជាមួយ PayPal។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:348
msgid "The issuer reversed the charge (chargeback)."
msgstr "អ្នកចេញផ្សាយបានត្រឡប់វិញការបង់ប្រាក់ (ការបង់ប្រាក់ត្រឡប់)។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:351
msgid "Payment by eCheck—awaiting clearance."
msgstr "ការទូទាត់ដោយ eCheck—កំពុងរង់ចាំការបញ្ជាក់។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:354
msgid "Action required in your PayPal account (international withdrawal)."
msgstr "សកម្មភាពត្រូវការនៅក្នុងគណនី PayPal របស់អ្នក (ការដកប្រាក់អន្តរជាតិ)។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:357
msgid "Payment pending manual review."
msgstr "ការទូទាត់កំពុងរង់ចាំការត្រួតពិនិត្យដោយដៃ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:360
msgid "Payee receiving preference requires action (often currency related)."
msgstr ""
"ការទទួលបានចំណូលពីអ្នកទទួលត្រូវការការប្រតិបត្តិ "
"(ជាញឹកញាប់ពាក់ព័ន្ធនឹងរូបិយវត្ថុ)។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:363
msgid "Funds were refunded."
msgstr "ប្រាក់បានត្រឡប់មកវិញ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:366
msgid "Approved—waiting for payer to send funds."
msgstr "អនុម័ត—កំពុងរង់ចាំអ្នកបង់ប្រាក់ដើម្បីផ្ញើប្រាក់។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:369
msgid "Payee does not have a PayPal account."
msgstr "Payee មិនមានគណនី PayPal ទេ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:372
msgid "Payee’s PayPal account requires verification."
msgstr "គណនី PayPal របស់អ្នកទទួលប្រាក់ត្រូវការការបញ្ជាក់។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:385
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1210
msgid "The transaction could not be completed."
msgstr "ប្រតិបត្តិការនេះមិនអាចបញ្ចប់បានទេ។."

#. translators: 1: payment method title, 2: pending reason text
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:393
msgid "Payment via %1$s pending. %2$s"
msgstr "ការទូទាត់តាម %1$s កំពុងរង់ចាំ។ %2$s"

#. translators: 1: payment method title, 2: decline reason text
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:405
msgid "Payment via %1$s declined. %2$s"
msgstr "ការទូទាត់តាម %1$s បានបដិសេធ។ %2$s"

#. translators: %s: payment failure reason
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:415
msgid "Payment declined. %s"
msgstr "ការទូទាត់ត្រូវបានបដិសេធ។ %s"

#. translators: 1: processor response code, 2: AVS result, 3: CVV result
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:428
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:465
msgid "Processor response: code=%1$s, AVS=%2$s, CVV=%3$s"
msgstr "Processor response: code=%1$s, AVS=%2$s, CVV=%3$s"

#. translators: 1: payment method title, 2: failure reason
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:442
msgid "Payment via %1$s failed. %2$s"
msgstr "ការទូទាត់តាម %1$s បានបរាជ័យ។ %2$s"

#. translators: %s: payment failure reason
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:452
msgid "Payment failed. %s"
msgstr "ការទូទាត់បានបរាជ័យ។ %s"

#. translators: 1: payment method title, 2: PayPal refund reason
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:480
msgid "Payment via %1$s partially refunded. PayPal reason: %2$s."
msgstr "ការទូទាត់តាម %1$s ត្រូវបានសងវិញផ្នែកមួយ។ មូលហេតុ PayPal: %2$s។."

#. translators: 1: payment method title, 2: PayPal refund reason
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:493
msgid "Payment via %1$s refunded. PayPal reason: %2$s."
msgstr "ការបង់ប្រាក់តាម %1$s ត្រូវបានសងវិញ។ មូលហេតុ PayPal: %2$s។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:509
msgid "An error occurred while updating the order status."
msgstr "កំហុសមួយបានកើតឡើងនៅពេលកំពុងអាប់ដេតស្ថានភាពការបញ្ជាទិញ។."


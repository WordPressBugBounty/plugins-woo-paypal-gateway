msgstr "PayPal បង់ក្រោយ"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1124
msgid "PayPal Checkout"
msgstr "PayPal Checkout"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1181
msgid "Approved."
msgstr "អនុម័ត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1182
msgid "The card security code (CVV) was incorrect."
msgstr "កូដសុវត្ថិភាពកាត (CVV) មិនត្រឹមត្រូវទេ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1183
msgid "Your bank needs to approve this. Please contact your card issuer."
msgstr ""
"ក្រុមហ៊ុនធនាគាររបស់អ្នកត្រូវការអនុម័តនេះ។ "
"សូមទំនាក់ទំនងទៅកាន់អ្នកចេញកាតរបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1184
msgid "We could not find this account. Please check your card details."
msgstr "យើងមិនអាចរកឃើញគណនីនេះទេ។ សូមពិនិត្យព័ត៌មានកាតរបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1185
msgid "The bank declined this transaction. Please try another payment method."
msgstr "ធនាគារបដិសេធប្រតិបត្តិការនេះ។ សូមព្យាយាមវិធីបង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1186
msgid "This transaction is not authorized. Please contact your card issuer."
msgstr ""
"ប្រតិបត្តិការនេះមិនត្រូវបានអនុញ្ញាតទេ។ "
"សូមទំនាក់ទំនងទៅកាន់អ្នកចេញកាតរបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1187
msgid "There was a processing issue. The payment was reversed."
msgstr "មានបញ្ហាការប្រតិបត្តិ។ ការទូទាត់ត្រូវបានត្រឡប់វិញ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1188
msgid "A security check failed. Please try again."
msgstr "ការត្រួតពិនិត្យសុវត្ថិភាពមួយបានបរាជ័យ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1189
msgid "The PIN was not accepted."
msgstr "PIN មិនត្រូវបានទទួលយក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1190
msgid "Temporary system issue. Please try again later."
msgstr "បញ្ហាប្រព័ន្ធបណ្តោះអាសន្ន។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1191
msgid "Payment was canceled."
msgstr "ការទូទាត់ត្រូវបានបោះបង់។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1192
msgid "Only part of the amount was approved."
msgstr "តែផ្នែកមួយនៃចំនួនត្រូវបានអនុម័ត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1193
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1211
msgid "The bank declined this transaction."
msgstr "បង់កបានបដិសេធប្រតិបត្តិការនេះ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1194
msgid "Invalid data format."
msgstr "ទម្រង់ទិន្នន័យមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1195
msgid "Invalid amount."
msgstr "ចំនួនមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1196
msgid "Card issuer/acquirer not allowed for this transaction."
msgstr "អ្នកចេញកាត/អ្នកទិញមិនអនុញ្ញាតសម្រាប់ប្រតិបត្តិការនេះ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1197
msgid "Invalid capture date."
msgstr "កាលបរិច្ឆេទចាប់យកមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1198
msgid "Unsupported currency for this card."
msgstr "កាសែតនេះមិនគាំទ្រទឹកប្រាក់សម្រាប់កាតនេះទេ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1199
msgid "Invalid account number."
msgstr "លេខគណនីមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1200
msgid "This card is not allowed for recurring payments."
msgstr "នេះកាតមិនអនុញ្ញាតសម្រាប់ការទូទាត់ជាប្រចាំទេ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1201
msgid "Invalid terminal configuration."
msgstr "កំណត់រចនាសម្ព័ន្ធបញ្ចូលមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1202
msgid "Invalid merchant configuration."
msgstr "កំណត់រចនាសម្ព័ន្ធអ្នកជួញដូរ​មិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1203
msgid "The account is restricted or inactive."
msgstr "គណនីត្រូវបានកំណត់ឬមិនសកម្ម។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1204
msgid "Invalid processing code."
msgstr "កូដដំណើរការមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1205
msgid "Invalid merchant category."
msgstr "ក្រុមប្រភេទពាណិជ្ជកម្មមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1206
msgid "Invalid card expiry date."
msgstr "កាលបរិច្ឆេទផុតកំណត់កាតមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1207
msgid "Invalid card security code (CVV)."
msgstr "កូដសុវត្ថិភាពកាត (CVV) មិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1208
msgid "Invalid transaction state."
msgstr "ស្ថានភាពប្រតិបត្តិការមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1209
msgid "Invalid order."
msgstr "ការបញ្ជាទិញមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1212
msgid "The card security code (CVV) did not match."
msgstr "កូដសុវត្ថិភាពកាត (CVV) មិនត្រូវគ្នាទេ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1213
msgid "Insufficient funds."
msgstr "ប្រាក់មិនគ្រប់គ្រាន់។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1214
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1225
msgid "Incorrect PIN."
msgstr "PIN មិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1215
msgid "Too many incorrect PIN attempts."
msgstr "PIN មិនត្រឹមត្រូវច្រើនពេក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1216
msgid "This card is closed."
msgstr "នេះកាតត្រូវបានបិទ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1217
msgid "Card capture requested by the bank."
msgstr "ការចាប់យកកាតបានស្នើសុំដោយធនាគារ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1218
msgid "User not authorized for this transaction."
msgstr "អ្នកប្រើប្រាស់មិនមានសិទ្ធិសម្រាប់ប្រតិបត្តិការនេះ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1219
msgid "Address verification failed."
msgstr "ការពិនិត្យអាសយដ្ឋានបានបរាជ័យ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1220
msgid "Invalid or restricted card."
msgstr "កាតមិនត្រឹមត្រូវ ឬមានកំណត់។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1221
msgid "Address verification soft failure."
msgstr "អាសយដ្ឋានការពិនិត្យមិនបានជោគជ័យ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1222
msgid "Duplicate transaction."
msgstr "ប្រតិបត្តិការដែលមានស្ទួន។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1223
msgid "Invalid transaction."
msgstr "ប្រតិបត្តិការមិនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1224
msgid "The card is expired."
msgstr "កាតបានផុតកំណត់។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1226
msgid "Strong customer authentication required."
msgstr "ការបញ្ជាក់អត្តសញ្ញាណអតិថិជនដែលមានកម្លាំងត្រូវការនេះ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1227
msgid "This type of transaction is not permitted."
msgstr "ប្រភេទនៃប្រតិបត្តិការនេះមិនអនុញ្ញាតទេ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1228
msgid "Too many attempts. Please try again later."
msgstr "ចំនួនការប៉ុនប៉ងច្រើនពេក។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1229
msgid "Invalid or restricted card. Please use another card."
msgstr "កាតមិនត្រឹមត្រូវ ឬកាតដែលមានកំណត់។ សូមប្រើកាតផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1230
msgid "Address verification soft failure. Please check your billing address."
msgstr ""
"ការពិនិត្យអាសយដ្ឋានបានបរាជ័យ។ សូមពិនិត្យអាសយដ្ឋានវិក័យប័ត្រ​របស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1231
msgid "Duplicate transaction. Please try again."
msgstr "ប្រតិបត្តិការដែលមានស្រាប់។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1232
msgid "Invalid transaction. Please try again."
msgstr "ប្រតិបត្តិការមិនត្រឹមត្រូវ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1233
msgid "Expired card. Please use another card."
msgstr "កាតបានផុតកំណត់។ សូមប្រើកាតផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1234
msgid "Incorrect PIN. Please re-enter your PIN."
msgstr "PIN មិនត្រឹមត្រូវ។ សូមបញ្ចូល PIN របស់អ្នកម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1235
msgid "Strong customer authentication required. Please try again."
msgstr "ការផ្ទៀងផ្ទាត់អតិថិជនដែលមានកម្លាំងត្រូវការនេះ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1236
msgid "Transaction not permitted. Please use another payment method."
msgstr "ប្រតិបត្តិការមិនអនុញ្ញាត។ សូមប្រើវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1237
msgid "Transaction attempts exceed limit. Please try again later."
msgstr "ការប៉ុនប៉ងប្រតិបត្តិការលើសកំណត់។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1238
msgid "Reversal rejected. Please contact support."
msgstr "ការបដិសេធការបង្វិល។ សូមទំនាក់ទំនងទៅកាន់ការគាំទ្រ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1239
msgid "Invalid issue. Please try again."
msgstr "បញ្ហាដែលមិនត្រឹមត្រូវ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1240
msgid "Issuer not available. Please try again later."
msgstr "អ្នកចេញសញ្ញាបត្រមិនអាចរកបាន។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1241
msgid "Issuer temporarily not available. Please try again shortly."
msgstr ""
"អ្នកចេញផ្សាយមិនអាចប្រើបានជាបណ្តោះអាសន្ន។ សូមព្យាយាមម្តងទៀតក្នុងពេលខ្លី។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1242
msgid "Card not activated. Please activate your card and try again."
msgstr "កាតមិនត្រូវបានសកម្ម។ សូមសកម្មកាតរបស់អ្នកហើយព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1243
msgid "Updated card issued. Please use your new card."
msgstr "កាតដែលបានអាប់ដេតត្រូវបានចេញ។ សូមប្រើកាតថ្មីរបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1244
msgid "Account not on file. Please check your card details."
msgstr "គណនីមិនមាននៅក្នុងឯកសារ។ សូមពិនិត្យព័ត៌មានកាតរបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1245
msgid "Approved but not captured. No action needed."
msgstr "អនុម័តប៉ុន្តែមិនបានចាប់យក។ មិនចាំបាច់មានសកម្មភាព។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1246
msgid "3DS authentication error. Please try again."
msgstr "កំហុសសុវត្ថិភាព 3DS។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1247
msgid "Authentication failed. Please try again."
msgstr "ការផ្ទៀងផ្ទាត់មិនបានជោគជ័យ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1248
msgid "BIN error. Please try another card."
msgstr "BIN កំហុស។ សូមព្យាយាមកាតផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1249
msgid "PIN error. Please try again with the correct PIN."
msgstr "កំហុស PIN។ សូមព្យាយាមម្តងទៀតជាមួយ PIN ដែលត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1250
msgid "Processor system error. Please try again later."
msgstr "កំហុសប្រព័ន្ធប្រព័ន្ធ។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1251
msgid "Host key error. Please try again."
msgstr "កំហុសកូនសោមេត្រី។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1252
msgid "Configuration error. Please contact support."
msgstr "កំហុសកំណត់។ សូមទំនាក់ទំនងការគាំទ្រ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1253
msgid "Unsupported operation. Please try another payment method."
msgstr "ការប្រតិបត្តិដែលមិនគាំទ្រ។ សូមព្យាយាមវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1254
msgid "Communication error. Please try again later."
msgstr "កំហុសក្នុងការទំនាក់ទំនង។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1255
msgid "Communication error. Please try again shortly."
msgstr "កំហុសក្នុងការទំនាក់ទំនង។ សូមព្យាយាមម្តងទៀតក្នុងពេលខ្លី។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1256
msgid "System unavailable. Please try again later."
msgstr "ប្រព័ន្ធមិនអាចប្រើបាន។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1257
msgid "Transaction declined. Please retry."
msgstr "ប្រតិបត្តិការបដិសេធ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1258
msgid "Suspected fraud. Please use another payment method."
msgstr "ការបោកប្រាស់ដែលគេសង្ស័យ។ សូមប្រើវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1259
msgid "Security violation. Please contact your card issuer."
msgstr "ការបំពានសុវត្ថិភាព។ សូមទំនាក់ទំនងទៅកាន់អ្នកចេញកាតរបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1260
msgid "Card reported lost or stolen. Please use another card."
msgstr "កាតត្រូវបានរាយការណ៍ថាបាត់ឬបានលួច។ សូមប្រើកាតផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1261
msgid "Hold - call center. Please contact your card issuer."
msgstr "រង់ចាំ - មជ្ឈមណ្ឌលទូរស័ព្ទ។ សូមទំនាក់ទំនងទៅកាន់អ្នកចេញកាតរបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1262
msgid "Card refused. Please use another payment method."
msgstr "កាតត្រូវបានបដិសេធ។ សូមប្រើវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1263
msgid "Unrecognized response code. Please try again later."
msgstr "កូដចម្លើយមិនស្គាល់។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1264
msgid "Contingencies not resolved. Please try again."
msgstr "ករណីដែលមិនបានដោះស្រាយ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1265
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1278
msgid "CVV verification failed. Please check your CVV."
msgstr "CVV ការពិនិត្យមិនបានជោគជ័យ។ សូមពិនិត្យមើល CVV របស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1266
msgid "Account closed. Please use another card."
msgstr "គណនីបានបិទ។ សូមប្រើកាតផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1267
msgid "Reattempt not permitted. Please use another payment method."
msgstr "ការប្រឡងម្តងទៀតមិនអនុញ្ញាតទេ។ សូមប្រើវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1268
msgid "Billing address error. Please check your billing details."
msgstr "កំហុសអាសយដ្ឋានវិក័យប័ត្រ។ សូមពិនិត្យព័ត៌មានវិក័យប័ត្ររបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1269
msgid "Account blocked by issuer. Please contact your card issuer."
msgstr ""
"គណនីត្រូវបានបិទដោយអ្នកចេញផ្សាយ។ សូមទំនាក់ទំនងទៅអ្នកចេញផ្សាយកាតរបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1270
msgid "American Express card disabled. Please use another card."
msgstr "កាត American Express ត្រូវបានបិទ។ សូមប្រើកាតផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1271
msgid "Adult gaming not supported. Please use another payment method."
msgstr ""
"ការលេងហ្គេមសម្រាប់មនុស្សពេញវ័យមិនត្រូវបានគាំទ្រ។ "
"សូមប្រើវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1272
msgid "Amount incompatible. Please try a different amount."
msgstr "ចំនួនមិនសមស្រប។ សូមព្យាយាមចំនួនផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1273
msgid "Authorization result error. Please try again."
msgstr "កំហុសលទ្ធផលអនុញ្ញាត។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1274
msgid "MCC code error. Please contact support."
msgstr "កំហុសកូដ MCC។ សូមទំនាក់ទំនងការគាំទ្រ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1275
msgid "Address verification failed. Please check your billing address."
msgstr "ការពិនិត្យអាសយដ្ឋានបានបរាជ័យ។ សូមពិនិត្យអាសយដ្ឋានវិក័យប័ត្ររបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1276
msgid "Amount exceeded. Please try a smaller amount."
msgstr "ចំនួនបានលើស។ សូមព្យាយាមចំនួនតិចជាងនេះ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1277
msgid "Gaming transaction error. Please use another payment method."
msgstr "កំហុសប្រតិបត្តិការការលេង។ សូមប្រើវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1279
msgid "Registration incomplete. Please complete registration."
msgstr "ការចុះឈ្មោះមិនពេញលេញ។ សូមបញ្ចប់ការចុះឈ្មោះ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1280
msgid "Country error. Please try another payment method."
msgstr "កំហុសប្រទេស។ សូមព្យាយាមវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1281
msgid "Credit error. Please try another payment method."
msgstr "កំហុសឥណទាន។ សូមព្យាយាមវិធីបង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1282
msgid "Card type not supported. Please use another card."
msgstr "ប្រភេទកាតមិនគាំទ្រ។ សូមប្រើកាតផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1283
msgid "Invalid currency. Please select a supported currency."
msgstr "ប្រាក់រូបិយវត្ថុមិនត្រឹមត្រូវ។ សូមជ្រើសរើសប្រាក់រូបិយវត្ថុដែលគាំទ្រ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1284
msgid "3D Secure authentication error. Please try again."
msgstr "កំហុសក្នុងការផ្ទៀងផ្ទាត់ 3D Secure។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1285
msgid "Dynamic currency conversion not supported. Please try again."
msgstr "ការបម្លែងរូបិយវត្ថុដំណើរការដោយសកម្មភាពមិនគាំទ្រ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1286
msgid "Diners Club card rejected. Please use another card."
msgstr "កាត Diners Club ត្រូវបានបដិសេធ។ សូមប្រើកាតផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1287
msgid "Authentication message error. Please try again."
msgstr "កំហុសសារបញ្ជាក់អត្តសញ្ញាណ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1288
msgid "Decline threshold exceeded. Please try again later."
msgstr "សម្រង់ការធ្លាក់ចុះបានលើស។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1289
msgid "Funding instrument expired. Please use another payment method."
msgstr "ឧបករណ៍ហិរញ្ញវត្ថុបានផុតកំណត់។ សូមប្រើវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1290
msgid "Frequency limit exceeded. Please try again later."
msgstr "កម្រិតភាពជាញឹកញាប់បានលើស។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1291
msgid "System error. Please try again later."
msgstr "កំហុសប្រព័ន្ធ។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1292
msgid "Expiry date error. Please check your card details."
msgstr "កំហុសថ្ងៃផុតកំណត់។ សូមពិនិត្យព័ត៌មានកាតរបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1293
msgid "Funding source already exists. Please use another payment method."
msgstr "ប្រភពថវិកាមានរួចហើយ។ សូមប្រើវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1294
msgid "Invalid funding instrument. Please try another payment method."
msgstr "ឧបករណ៍ហិរញ្ញវត្ថុមិនត្រឹមត្រូវ។ សូមព្យាយាមវិធីបង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1295
msgid "Restricted funding instrument. Please try another payment method."
msgstr "ឧបករណ៍ហិរញ្ញវត្ថុដែលមានកំណត់។ សូមព្យាយាមវិធីបង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1296
msgid "Field validation failed. Please check your payment details."
msgstr "ការត្រួតពិនិត្យវាលបានបរាជ័យ។ សូមពិនិត្យព័ត៌មានការទូទាត់របស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1297
msgid "Gaming refund error. Please contact support."
msgstr "កំហុសការត្រឡប់ប្រាក់កាស៊ីណូ។ សូមទំនាក់ទំនងគាំទ្រ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1298
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1307
msgid "Processing error. Please try again."
msgstr "កំហុសក្នុងការប្រតិបត្តិការ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1299
msgid "Idempotency failure. Please try again."
msgstr "Idempotensi gagal. Sila cuba lagi."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1300
msgid "Invalid input. Please check your payment details."
msgstr "ចំណុចបញ្ចូលមិនត្រឹមត្រូវ។ សូមពិនិត្យព័ត៌មានការទូទាត់របស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1301
msgid "ID mismatch. Please try again."
msgstr "ID មិនត្រូវគ្នា។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1302
msgid "Invalid trace ID. Please try again."
msgstr "ID trace yang tidak sah. Sila cuba lagi."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1303
msgid "Late reversal. Please contact support."
msgstr "ការបង្វិលយឺត។ សូមទំនាក់ទំនងទៅកាន់ការគាំទ្រ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1304
msgid "Status code error. Please try again."
msgstr "កូដស្ថានភាពកំហុស។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1305
msgid "Missing business rule or data. Please try again."
msgstr "ច្បាប់អាជីវកម្មឬទិន្នន័យខ្វះ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1306
msgid "Mastercard blocked. Please use another card."
msgstr "Mastercard បានបិទ។ សូមប្រើកាតផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1308
msgid "Not supported. Please try another payment method."
msgstr "មិនគាំទ្រ។ សូមព្យាយាមវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1309
msgid "Network frequency limit exceeded. Please try again later."
msgstr "កម្រិតឌីជីថលបណ្តាញបានលើស។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1310
msgid "Merchant ID not found. Please contact support."
msgstr "Merchant ID មិនបានរកឃើញ។ សូមទំនាក់ទំនងការគាំទ្រ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1311
msgid "Network error. Please try again later."
msgstr "កំហុសបណ្តាញ។ សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1312
msgid "Phone required for this transaction. Please update your details."
msgstr "Phone diperlukan untuk transaksi ini. Sila kemas kini butiran anda."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1313
msgid "Invalid product. Please try another product."
msgstr "ផលិតផលមិនត្រឹមត្រូវ។ សូមព្យាយាមផលិតផលផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1314
msgid "Invalid payment method. Please try another payment method."
msgstr ""
"វិធីសាស្ត្របង់ប្រាក់មិនត្រឹមត្រូវ។ សូមព្យាយាមវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1315
msgid "Quasi-cash not supported. Please use another payment method."
msgstr "Quasi-cash មិនត្រូវបានគាំទ្រ។ សូមប្រើវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1316
msgid "Refund not supported on pending transactions. Please try again later."
msgstr ""
"ការបង្វិលប្រាក់មិនគាំទ្រនៅលើប្រតិបត្តិការដែលកំពុងរង់ចាំ។ "
"សូមព្យាយាមម្តងទៀតនៅពេលក្រោយ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1317
msgid "Invalid parent transaction status. Please try again."
msgstr "ស្ថានភាពប្រតិបត្តិការមាតុភូមិមិនត្រឹមត្រូវ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1318
msgid "Merchant not registered. Please contact support."
msgstr "អ្នកជួញដូរ​មិនបានចុះឈ្មោះ។ សូមទំនាក់ទំនងការគាំទ្រ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1319
msgid "Bank authorization mismatch. Please try again."
msgstr "ការអនុញ្ញាតធនាគារមិនត្រូវគ្នា។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1320
msgid "Bank authorization already settled. Please try again."
msgstr "អាជ្ញាប័ណ្ណធនាគារបានដោះស្រាយរួចរាល់។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1321
msgid "Bank authorization voided. Please try again."
msgstr "ការអនុញ្ញាតធនាគារត្រូវបានបោះបង់។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1322
msgid "Bank authorization expired. Please try again."
msgstr "ការអនុញ្ញាតធនាគារបានផុតកំណត់។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1323
msgid "Currency mismatch. Please try again with the correct currency."
msgstr "ប្រាក់កាសមិនត្រូវគ្នា។ សូមព្យាយាមម្តងទៀតជាមួយប្រាក់កាសត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1324
msgid "Credit card mismatch. Please check your card details."
msgstr "កាតឥណទានមិនត្រូវគ្នា។ សូមពិនិត្យព័ត៌មានកាតរបស់អ្នក។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1325
msgid "Amount mismatch. Please try again with the correct amount."
msgstr "ចំនួនមិនត្រឹមត្រូវ។ សូមព្យាយាមម្តងទៀតជាមួយចំនួនត្រឹមត្រូវ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1326
msgid "Score error. Please try again."
msgstr "កំហុសពិន្ទុ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1327
msgid "Status description error. Please try again."
msgstr "ការពិពណ៌នាស្ថានភាពកំហុស។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1328
msgid "American Express declined. Please use another card."
msgstr "American Express បានបដិសេធ។ សូមប្រើកាតផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1329
msgid "Verification token expired. Please try again."
msgstr "Token verifikasi telah kedaluwarsa. Silakan coba lagi."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1330
msgid "Invalid trace reference. Please try again."
msgstr "ការយោងតាមត្រាបមិនត្រឹមត្រូវ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1331
msgid "Invalid transaction ID. Please try again."
msgstr "ID transaksi tidak sah. Sila cuba lagi."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1332
msgid "Verification token revoked. Please try again."
msgstr "Verification token đã bị thu hồi. Vui lòng thử lại."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1333
msgid "Transaction type not supported. Please try another payment method."
msgstr ""
"ប្រភេទប្រតិបត្តិការមិនគាំទ្រ។ សូមព្យាយាមវិធីសាស្ត្របង់ប្រាក់ផ្សេងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1334
msgid "Invalid verification token. Please try again."
msgstr "កូដបញ្ជាក់មិនត្រឹមត្រូវ។ សូមព្យាយាមម្តងទៀត។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1335
msgid "User not authorized. Please contact support."
msgstr "អ្នកប្រើប្រាស់មិនមានអាជ្ញាប័ណ្ណ។ សូមទំនាក់ទំនងការគាំទ្រ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1336
msgid "Currency not supported. Please select a supported currency."
msgstr "កាសែតមិនគាំទ្រ។ សូមជ្រើសរើសកាសែតដែលគាំទ្រ។."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1337
msgid "Entity not supported. Please try another payment method."
msgstr "Entity មិនគាំទ្រ។ សូមព្យាយាមវិធីសាស្រ្តបង់ប្រាក់ផ្សេងទៀត។."

